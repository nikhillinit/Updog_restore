[
  {
    "name": "Initial Load (Critical Path)",
    "strategy": "manifest-entry-closure",
    "entry": "index.html",
    "limit": "165 KB",
    "gzip": true
  },
  {
    "name": "Largest JavaScript Chunk",
    "strategy": "glob-max",
    "path": "dist/public/assets/*.js",
    "limit": "140 KB",
    "gzip": true
  }
]
