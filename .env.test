# Safe deterministic defaults for local and CI test runs.
# server/config/index.ts loads this file when NODE_ENV=test; machine-local
# overrides belong in ignored .env.test.local.

NODE_ENV=test
TZ=UTC
REDIS_URL=memory://
SESSION_SECRET=test-session-secret-must-be-at-least-32-characters-long
JWT_ALG=HS256
JWT_SECRET=test-jwt-secret-must-be-at-least-32-characters-long-for-hs256-validation
JWT_ISSUER=updog
JWT_AUDIENCE=updog-app
