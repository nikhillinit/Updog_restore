# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Scripts - always LF for cross-platform compatibility
*.sh text eol=lf
*.mjs text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf

# Windows scripts - CRLF
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Config files - LF
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
package-lock.json text eol=lf
*.toml text eol=lf
*.xml text eol=lf
*.sql text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
.env* text eol=lf
.gitignore text eol=lf
.eslintrc* text eol=lf
.prettierrc* text eol=lf

# Documentation - LF
*.md text eol=lf
LICENSE text eol=lf
README text eol=lf

# Archive and generated-directory hygiene.
#
# These attributes affect GitHub Linguist/diff presentation and git archive
# output. They do not reduce git clone or git fetch transfer size.
archive/** linguist-generated export-ignore
docs/archive/** linguist-generated export-ignore
docs/_generated/** linguist-generated export-ignore
.backup/** linguist-generated export-ignore
.claude/skills/INDEX.md linguist-generated
.claude/skills/_index.json linguist-generated

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
