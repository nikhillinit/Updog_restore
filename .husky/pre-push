#!/usr/bin/env bash

if [ -z "${BASH_VERSION:-}" ]; then
  exec bash "$0" "$@"
fi

set -euo pipefail

REPO_ROOT=$(git rev-parse --show-toplevel)
PATH="$REPO_ROOT/node_modules/.bin:$PATH"

echo "Checking changed files against origin/main..."

# Ensure origin/main is up to date for accurate comparison
git fetch origin main 2>/dev/null || true
BASE_BRANCH="origin/main"

# Control plane: Large file scan (unless hooks disabled)
if [ -z "${CLAUDE_HOOKS_DISABLE:-}" ]; then
  echo "Scanning for large files..."
  node scripts/control-plane/git-safety.mjs pre-push "$BASE_BRANCH" "HEAD" || {
    echo ""
    echo "Large file check failed. See above for details."
    echo "Add files to .claude/large-file-allowlist.json if intentional."
    exit 1
  }
fi

# Get changed files since the common ancestor
CHANGED=$(git diff --name-only $BASE_BRANCH...HEAD || echo "")

if [ -z "$CHANGED" ]; then
  echo "✅ No changes detected, skipping tests"
  exit 0
fi

CLASSIFICATION=$(printf '%s\n' "$CHANGED" | node scripts/pre-push-classification.mjs)

case "$CLASSIFICATION" in
  docs-only-skip)
    echo "✅ Docs/config-only changes; skipping tests"
    exit 0
    ;;
  full-run|type-fix-only-skip|targeted)
    ;;
  *)
    echo "❌ Unknown pre-push classification: $CLASSIFICATION"
    exit 1
    ;;
esac

# Documentation freshness check (warning only, non-blocking)
echo "📄 Checking documentation freshness..."
node scripts/check-doc-freshness.mjs || {
  echo ""
  echo "⚠️  STALE documentation detected (warning only)"
  echo "   Consider updating documents flagged above"
  echo ""
}

# TypeScript baseline check (always run if code changed)
echo "📋 Checking TypeScript baseline..."
npm run baseline:check || {
  echo ""
  echo "❌ NEW TypeScript errors detected"
  echo ""
  echo "If you FIXED errors:"
  echo "   npm run baseline:save && git add .tsc-baseline.json && git commit --amend --no-edit"
  echo ""
  echo "If you INTRODUCED errors:"
  echo "   Fix them or see: npm run baseline:progress"
  exit 1
}

# Orphan test discovery gate (REFL-036)
# --no-renames decomposes renames into add+delete pairs so --diff-filter=ACM
# inspects only the destination path (the new file) plus real adds/modifications.
# Pure deletions are ignored - removing an orphaned test should never block a push.
echo "Checking for orphan tests in __tests__ directories..."
ORPHAN_CHECK_FILES=$(git diff --no-renames --name-only --diff-filter=ACM "$BASE_BRANCH"...HEAD 2>/dev/null | tr '\n' ' ')
if [ -n "$ORPHAN_CHECK_FILES" ]; then
  node scripts/check-orphan-tests.mjs $ORPHAN_CHECK_FILES || exit 1
fi

# If core configuration files changed, run the full test suite
if [ "$CLASSIFICATION" = "full-run" ]; then
  echo "⚠️  Core configuration changed, running full validation..."

  # Build verification
  echo "🏗️  Building..."
  npm run build || exit 1

  # Full test suite
  echo "🧪 Running full test suite..."
  npm test
  exit $?
fi

# Otherwise, run only affected tests (smart mode)
echo "🧪 Running targeted tests for changed files..."
# For error boundary and CHANGELOG changes, skip all tests (type-safety already verified)
if [ "$CLASSIFICATION" = "type-fix-only-skip" ]; then
  echo "ℹ️  Type-fix only changes detected (ErrorBoundary/LoadingState/CHANGELOG)"
  echo "   TypeScript baseline check already passed"
  echo "   Skipping test suite (no behavioral changes)"
  exit 0
fi

mapfile -t CHANGED_FILES < <(printf '%s\n' "$CHANGED" | sed '/^$/d')

# Run only tests related to the changed file set. Calling Vitest directly avoids
# npm script argument forwarding quirks that can silently fall back to the full
# unit suite.
npx vitest related "${CHANGED_FILES[@]}" --run --config "$REPO_ROOT/vitest.config.mjs" --configLoader native --project=server --project=client
exit $?
