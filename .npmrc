package-lock=true
save-exact=true
engine-strict=false

# Project-local npm configuration for post-sidecar architecture
# Created during sidecar elimination migration (2025-12-20)
# Updated 2025-12-27: Relaxed engine-strict for Node 20.x/22.x compatibility
# Updated 2026-04-21: Keep Windows npm shell config out of repo-level npmrc so
# Linux CI does not inherit cmd.exe as its script shell. Windows-specific shell
# hardening belongs in user-level config and bootstrap helpers.

# Use project-local npm cache and temporary directories
cache=.npm-cache
tmp=.npm-tmp

# Ensure npm uses local cache first
prefer-offline=false
prefer-online=true
cache-max=Infinity
cache-min=0

# Log level for debugging if needed
loglevel=warn
