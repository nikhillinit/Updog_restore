    "calc-gate:full": "npm run calc-gate && cross-env TZ=UTC vitest run tests/unit/bootstrap/ready-file-handshake.test.ts tests/unit/contract/funds-endpoint-snapshots.test.ts tests/unit/contract/funds-route-ownership.test.ts tests/unit/contract/funds-boundary-guard.test.ts tests/unit/engines/reserve-engine.test.ts tests/unit/engines/pacing-engine.test.ts tests/unit/engines/cohort-engine.test.ts tests/unit/fund-calc-fee-horizon.test.ts --project=server && cross-env TZ=UTC vitest run tests/unit/pages/fund-model-results.test.tsx --project=client && cross-env TZ=UTC vitest run tests/integration/wizard-to-results-e2e.test.ts --config vitest.config.int.ts",
