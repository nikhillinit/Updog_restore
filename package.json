    "quarantine:report": "tsx scripts/quarantine-report.ts",
    "test:ui": "vitest --ui",
    "test:quick": "vitest run --exclude='**/api/**'",
    "test:publish-orchestration": "cross-env TZ=UTC vitest run tests/unit/phase2a/fund-persistence-service.behavior.test.ts tests/unit/phase2a/calc-run-tracking.test.ts tests/unit/phase2a/config-invariants.test.ts --project=server",
