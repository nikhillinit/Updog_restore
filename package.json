  "scripts": {
    "preinstall": "node scripts/check-package-manager.mjs",
    "doctor": "node scripts/doctor.mjs",
    "doctor:shell": "node scripts/doctor-shell.mjs",
    "doctor:quick": "node scripts/doctor-quick.mjs",
    "dev": "npx concurrently -k \"npm run dev:client\" \"npm run dev:api\"",
    "clean:spa-dist": "node scripts/clean-spa-dist.mjs",
    "dev:client": "npx vite",
    "dev:api": "npx tsx server/main.ts",
    "build:web": "npm run clean:spa-dist && npx vite build --mode preact",
    "build:server": "node scripts/build-server.mjs",
    "build:prod": "npm run build:web && npm run build:server",
    "build": "npm run build:prod",
    "preview": "npx vite preview",
    "postbuild": "node scripts/verify-build.mjs",
    "vercel-build": "npm run clean:spa-dist && npx vite build",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "baseline:check": "node scripts/typescript-baseline.cjs check",
    "check": "npm run baseline:check",
    "ci:telemetry": "node scripts/ci-live-telemetry.mjs",
    "validate:core": "npm run baseline:check && npm run test:publish-orchestration && cross-env TZ=UTC vitest run tests/unit/bootstrap/ready-file-handshake.test.ts tests/unit/contract/funds-endpoint-snapshots.test.ts tests/unit/contract/funds-route-ownership.test.ts tests/unit/contract/funds-boundary-guard.test.ts tests/unit/engines/reserve-engine.test.ts tests/unit/engines/pacing-engine.test.ts tests/unit/engines/cohort-engine.test.ts tests/unit/fund-calc-fee-horizon.test.ts --project=server && cross-env TZ=UTC vitest run tests/unit/pages/fund-model-results.test.tsx --project=client && cross-env TZ=UTC vitest run tests/integration/wizard-to-results-e2e.test.ts --config vitest.config.int.ts && eslint --no-cache --no-ignore --max-warnings 0 server/routes.ts server/routes/funds.ts server/routes/calculations.ts server/services/projected-metrics-calculator.ts server/contracts/funds-endpoint-ownership.ts shared/core/reserves/ReserveEngine.ts shared/core/pacing/PacingEngine.ts shared/core/cohorts/CohortEngine.ts shared/lib/fund-calc.ts shared/utils/pLimit.ts shared/utils/resilientLimit.ts client/src/core/reserves/ReserveEngine.ts client/src/core/pacing/PacingEngine.ts client/src/core/cohorts/CohortEngine.ts client/src/lib/fund-calc.ts client/src/utils/pLimit.ts client/src/utils/resilientLimit.ts tests/unit/contract/funds-endpoint-snapshots.test.ts tests/unit/contract/funds-route-ownership.test.ts tests/unit/contract/funds-boundary-guard.test.ts && node scripts/guardrails/phase4-worker-eslint-ratchet.mjs",
    "release:check": "node scripts/release-check.mjs",
    "validate:schema-drift": "tsx scripts/schema-drift-active-surfaces.ts",
    "bundle:check": "node scripts/check-budgets.cjs",
    "lint:eslint": "eslint . --max-warnings 0 --cache --cache-location .cache/eslint",
    "lint": "npm run lint:eslint && npm run guardrails:check",
    "lint:fix": "eslint . --fix --cache --cache-location .cache/eslint",
    "guard:console:check": "node scripts/guardrails/console-ratchet.mjs",
    "guard:eslint-disable:check": "node scripts/guardrails/eslint-disable-ratchet.mjs",
    "guard:scripts:check": "node scripts/guardrails/script-alias-policy.mjs",
    "guard:route-imports:check": "node scripts/guardrails/route-persistence-imports.mjs",
    "guardrails:check": "npm run guard:console:check && npm run guard:eslint-disable:check && npm run guard:scripts:check && npm run guard:route-imports:check",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed:demo": "cross-env DEMO_SEED=1 npx tsx server/seed-demo-data.ts",
    "demo-profile:import": "npx tsx scripts/import-demo-profile.ts",
    "demo-profile:verify": "npx tsx scripts/verify-demo-profile.ts",
